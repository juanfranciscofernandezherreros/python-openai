# ============================================================
# Variables de entorno para generateArticle.py
#
# Uso:
#   cp .env.example .env
#   # Edita .env con tus valores reales
#   python generateArticle.py --tag "JWT Authentication" \
#       --category "Spring Boot" --subcategory "Spring Security"
#
# IMPORTANTE:
#   - Este fichero (.env.example) es una PLANTILLA segura para versionar.
#   - El fichero .env con valores reales NUNCA debe subirse al repositorio.
#   - generateArticle.py NO requiere MongoDB; exporta el artículo a JSON.
#
# Leyenda:
#   [OBLIGATORIA] — el script no funciona sin esta variable (según el proveedor elegido)
#   [RECOMENDADA] — mejora el resultado pero tiene un valor por defecto razonable
#   [OPCIONAL]    — no es necesaria para el uso básico
# ============================================================


# ================================================================
# SECCIÓN 1 — PROVEEDOR DE IA
# ================================================================
# El script admite tres proveedores de IA. Elige UNO y configura
# las variables del proveedor seleccionado:
#
#   Proveedor       | OPENAI_MODEL ejemplo        | Clave necesaria
#   ----------------+-----------------------------+-----------------
#   OpenAI (GPT)    | gpt-4o                      | OPENAIAPIKEY
#   Google Gemini   | gemini-2.0-flash            | GEMINI_API_KEY
#   Ollama (local)  | llama3                      | solo OLLAMA_BASE_URL
# ================================================================

# ---- Modelo de IA a usar [OBLIGATORIA] ----
# Controla qué proveedor e IA se usa:
#   - Modelos OpenAI  : gpt-4o | gpt-4-turbo | gpt-3.5-turbo
#   - Modelos Gemini  : gemini-2.0-flash | gemini-1.5-pro | gemini-1.5-flash
#   - Modelos Ollama  : llama3 | mistral | codellama | gemma | phi3
# Por defecto: gpt-4o
OPENAI_MODEL=gpt-4o


# ---- OpenAI / ChatGPT [OBLIGATORIA si OPENAI_MODEL es un modelo OpenAI] ----
# Obtén tu clave en: https://platform.openai.com/api-keys
OPENAIAPIKEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX


# ---- Google Gemini [OBLIGATORIA si OPENAI_MODEL es un modelo gemini-*] ----
# Obtén tu clave en: https://aistudio.google.com/app/apikey
# Ejemplo de uso: cambia también OPENAI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=AIzaSy-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX


# ---- Ollama — LLM local, sin clave de API [OPCIONAL] ----
# Instala Ollama desde https://ollama.com y descarga el modelo:
#   ollama pull llama3
# Luego descomenta las dos líneas de abajo y establece OPENAI_MODEL al modelo deseado.
# Cuando OLLAMA_BASE_URL está definida, el script usa Ollama y NO necesita OPENAIAPIKEY.
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3


# ================================================================
# SECCIÓN 2 — PARÁMETROS DE GENERACIÓN
# ================================================================

# Temperatura para la generación del cuerpo del artículo [RECOMENDADA]
# Rango: 0.0 (determinista / conservador) → 1.0 (creativo / variado)
# Por defecto: 0.7
AI_TEMPERATURE_ARTICLE=0.7

# Temperatura para la generación del título del artículo [RECOMENDADA]
# Un valor más alto produce títulos más variados y creativos.
# Por defecto: 0.9
AI_TEMPERATURE_TITLE=0.9

# Idioma de los artículos generados (código ISO 639-1) [RECOMENDADA]
# Códigos soportados: es | en | fr | de | it | pt | nl | pl | ru | zh | ja | ar
# Por defecto: es (español)
ARTICLE_LANGUAGE=es


# ================================================================
# SECCIÓN 3 — IDENTIDAD DEL SITIO Y AUTOR
# ================================================================

# URL base del sitio web, SIN barra final [RECOMENDADA]
# Se usa para construir URLs canónicas (canonicalUrl) y datos estructurados JSON-LD.
# Ejemplo: https://tusitio.com
SITE=https://tusitio.com

# Username o nombre del autor de los artículos generados [RECOMENDADA]
# Se incluye en el campo "author" del JSON generado y en los datos estructurados.
# Por defecto: adminUser
AUTHOR_USERNAME=adminUser


# ================================================================
# SECCIÓN 4 — NOTIFICACIONES POR EMAIL (SMTP)
# ================================================================
# Todas las variables de esta sección son OPCIONALES.
# Si se omiten, el script funciona igualmente pero no enviará emails.
#
# Para Gmail:
#   1. Activa la verificación en dos pasos: https://myaccount.google.com/security
#   2. Crea una contraseña de aplicación: https://myaccount.google.com/apppasswords
#   3. Usa esa contraseña en SMTP_PASS (NO tu contraseña habitual de Gmail).
# ================================================================

# Servidor SMTP [OPCIONAL]
# Ejemplos: smtp.gmail.com | smtp.office365.com | mail.tu-empresa.com
SMTP_HOST=smtp.gmail.com

# Puerto SMTP [OPCIONAL]
# Puertos habituales: 587 (STARTTLS, recomendado) | 465 (SSL) | 25 (sin cifrado)
# Por defecto: 587
SMTP_PORT=587

# Credenciales SMTP [OPCIONAL]
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_contraseña_de_aplicacion

# Dirección de origen del email [OPCIONAL]
# Si se omite, se usa el valor de SMTP_USER.
FROM_EMAIL=tu_correo@gmail.com

# Dirección de destino de las notificaciones [OPCIONAL]
NOTIFY_EMAIL=tu_correo@gmail.com


# ================================================================
# SECCIÓN 5 — COMPORTAMIENTO DE LAS NOTIFICACIONES
# ================================================================

# Enviar emails detallados con información del artículo generado [OPCIONAL]
# Valores: true | false
# Por defecto: true
NOTIFY_VERBOSE=true

# Enviar por email el prompt completo antes de llamar a la IA [OPCIONAL]
# Útil para depuración y auditoría de prompts.
# Valores: true | false
# Por defecto: false
SEND_PROMPT_EMAIL=false
